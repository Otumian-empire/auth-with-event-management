{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": false,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2016",
    "strictNullChecks": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "incremental": true,
    "typeRoots": ["./src/types", "./node_modules/@types"],
    "types": ["node"],
    "lib": ["ES2016"],
    "allowJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "resolveJsonModule": true,
    "strictPropertyInitialization": false
  },
  "include": ["src/**/*"],
  "exclude": [
    "eslint.config.mjs",
    "node_modules",
    "node_modules/**/*",
    "dist",
    "*Dist"
  ]
}
