{
  "name": "auth-with-event-management",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec npx ts-node --files src/index.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "build": "rimraf ./dist && npx tsc -b --force",
    "migration:create": "npx typeorm migration:create",
    "migration:generate": "npm run build && npx typeorm migration:generate -d dist/database/data-source.js",
    "migration:run": "npm run build && npx typeorm migration:run -d dist/database/data-source.js",
    "migration:show": "npm run build && npx typeorm migration:show -d dist/database/data-source.js",
    "migration:undo": "npm run build && npx typeorm migration:revert -d dist/database/data-source.js",
    "format": "npx prettier --write ./src",
    "clean": "npx rimraf dist tsconfig.tsbuildinfo"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/joi": "^17.2.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "@types/redis": "^4.0.10",
    "dotenv": "^17.3.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "express": "^5.2.1",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28"
  }
}
